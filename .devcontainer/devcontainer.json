{
  "name": "Python Codespace",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",

  // Install extra Python packages here if you like:
  // "postCreateCommand": "pip install --upgrade pip && pip install jupyter numpy pandas matplotlib",

  "customizations": {
    "vscode": {
      "settings": {
        // --- AI / inline suggestions off ---
        "editor.inlineSuggest.enabled": false,        // disables ghost‑text style suggestions (Copilot etc.)
        "github.copilot.enable": {                   // if Copilot is installed, disable it everywhere
          "*": false,
          "plaintext": false,
          "markdown": false,
          "scminput": false
        },

        // --- Strongly reduce autocomplete / hints ---
        "editor.suggestOnTriggerCharacters": false,  // no popup on "." or similar
        "editor.quickSuggestions": {                 // no live suggestions as you type
          "other": false,
          "comments": false,
          "strings": false
        },
        "editor.parameterHints.enabled": false,      // no “parameter hint” popups
        "editor.hover.enabled": "onKeyboardModifier",   // no hover docs popping up
        "python.analysis.autoImportCompletions": false, // no auto-import suggestions
        "editor.tabCompletion": "off"                // no tab‑completion cycling
      },
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter"
        // NOTE: do NOT list GitHub Copilot or other AI extensions here
      ]
    }
  }
}
